# Copy thành /etc/luna/luna.env trên VM rồi điền giá trị thật. KHÔNG commit file thật.
# (Giống .env.example ở root nhưng dùng cho container; DATABASE_URL trỏ service `db`.)

LUNA_ENV=production
LOG_LEVEL=INFO
SECRET_KEY=

# DB: dùng service `db` trong compose, hoặc trỏ sang Supabase.
DATABASE_URL=postgresql+psycopg://luna:luna@db:5432/luna

# Claude Code CLI
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_TIMEOUT_S=1800

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/etc/luna/github-app.pem
GITHUB_APP_WEBHOOK_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Username bot (không @) — cần khi dùng GROUP ở mode webhook để nhận diện @mention.
# Mode polling tự lấy qua getMe nên có thể để trống.
TELEGRAM_BOT_USERNAME=

# Google Chat (channel thay thế cho ai không có Telegram) — xem deploy/google-chat-setup.md
GOOGLE_CHAT_ENABLED=false
GOOGLE_CHAT_SA_JSON=/etc/luna/google-chat-sa.json
GOOGLE_CHAT_PROJECT_NUMBER=

# Git identity của bot
GIT_AUTHOR_NAME=luna bot
GIT_AUTHOR_EMAIL=bot@luna.dev
