# Copy thành /etc/luna/luna.env trên VM rồi điền giá trị thật. KHÔNG commit file thật.
# (Giống .env.example ở root nhưng dùng cho container; DATABASE_URL trỏ service `db`.)

LUNA_ENV=production
LOG_LEVEL=INFO
SECRET_KEY=

# DB: dùng service `db` trong compose, hoặc trỏ sang Supabase.
DATABASE_URL=postgresql+psycopg://luna:luna@db:5432/luna

# Claude Code CLI
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_TIMEOUT_S=1800

# Deploy-gate sau khi merge vào dev: chờ GitHub Action build+deploy + curl trang dev (200)
# rồi mới mời manager. BẬT MẶC ĐỊNH cho MỌI repo. Tắt toàn cục: DEV_VERIFY_ENABLED=false.
# Opt-OUT 1 repo: settings_json.deploy_gate=false. Repo không có CI deploy được tự phát hiện
# (sau DEPLOY_CI_GRACE_S không thấy workflow nào → bỏ qua cổng, mời manager ngay).
# dev_url TỰ DÒ từ repo (.firebaserc/firebase.json/workflow → https://<site>.web.app), cache vào
# dev_url_auto. Tuỳ chọn: dev_url (override, vd custom domain), deploy_workflow (lọc đúng workflow).
DEPLOY_CI_GRACE_S=90
# Build-gate sớm: MẶC ĐỊNH Claude TỰ dò các lệnh kiểm tra KHÔNG cần env của dự án (lint/typecheck/
# unit) rồi chạy tới khi xanh TRƯỚC khi app push — không cần cấu hình gì. repositories.settings_json
# .build_cmd là OVERRIDE tuỳ chọn (ép đúng một lệnh). LƯU Ý: container luna KHÔNG có env/secret app
# khách → chỉ chạy lệnh env-free; build/deploy đầy đủ (cần secret) do deploy-gate B1 (CI repo khách) lo.
DEV_VERIFY_ENABLED=true
DEPLOY_POLL_INTERVAL_S=15
DEPLOY_TIMEOUT_S=900
DEV_VERIFY_MAX_ROUNDS=2

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/etc/luna/github-app.pem
GITHUB_APP_WEBHOOK_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Username bot (không @) — cần khi dùng GROUP ở mode webhook để nhận diện @mention.
# Mode polling tự lấy qua getMe nên có thể để trống.
TELEGRAM_BOT_USERNAME=

# Google Chat (channel thay thế cho ai không có Telegram) — xem deploy/google-chat-setup.md
GOOGLE_CHAT_ENABLED=false
GOOGLE_CHAT_SA_JSON=/etc/luna/google-chat-sa.json
GOOGLE_CHAT_PROJECT_NUMBER=

# --- Web wizard self-service (tạo bot cho repo của khách) — xem deploy/self-service.md ---
# Đặt đủ 4 biến đầu để BẬT wizard. Để trống = tắt (trang / báo "chưa cấu hình").
PUBLIC_BASE_URL=                       # vd https://luna.fechtin.com (dựng OAuth callback + webhook đa bot)
GITHUB_OAUTH_CLIENT_ID=                # GitHub App → tab "OAuth credentials"
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_APP_SLUG=                        # slug trong https://github.com/apps/<slug>
WEB_SESSION_SECRET=                     # chuỗi ngẫu nhiên bền (ký cookie phiên)
# Fernet key mã hoá token bot riêng (BYO). Sinh:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BOT_TOKEN_ENC_KEY=
# Bật "container riêng" trong wizard (CẦN mount Docker socket — rủi ro bảo mật). Mặc định false.
DEDICATED_CONTAINER_ENABLED=false

# Git identity của bot
GIT_AUTHOR_NAME=luna bot
GIT_AUTHOR_EMAIL=bot@luna.dev
