# luna — copy thành `.env` (local) hoặc `/etc/luna/luna.env` (VM). KHÔNG commit file thật.

# --- App ---
LUNA_ENV=development
LOG_LEVEL=INFO
# Bí mật chung của app (ký link_token, v.v.)
SECRET_KEY=change-me

# --- Database (Postgres self-hosted; KHÔNG dùng chung DB internal) ---
# psycopg3 dsn: postgresql+psycopg://user:pass@host:5432/dbname
# Local: localhost. Trong compose: host = service `db`. Muốn Supabase = đổi dsn này.
DATABASE_URL=postgresql+psycopg://luna:luna@localhost:5432/luna

# --- Claude Code CLI (M1) ---
# Subscription OAuth: chạy `claude setup-token` rồi dán sk-ant-oat...
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_TIMEOUT_S=1800

# --- GitHub App (M2) ---
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/etc/luna/github-app.pem
GITHUB_APP_WEBHOOK_SECRET=

# --- Telegram (M3) ---
TELEGRAM_BOT_TOKEN=
# Secret header xác thực webhook Telegram (X-Telegram-Bot-Api-Secret-Token)
TELEGRAM_WEBHOOK_SECRET=

# --- Workspace ---
WORKSPACE=/workspace

# --- Git identity của bot ---
GIT_AUTHOR_NAME=luna bot
GIT_AUTHOR_EMAIL=bot@luna.dev
